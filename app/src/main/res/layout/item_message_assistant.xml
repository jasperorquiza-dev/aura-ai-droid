<?xml version="1.0" encoding="utf-8"?>
<!-- Assistant message bubble - left aligned with glassmorphism card -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="top"
    android:layout_marginTop="6dp"
    android:layout_marginEnd="48dp"
    android:layout_marginStart="4dp">

    <!-- AI avatar -->
    <LinearLayout
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_ai_avatar_small"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦"
            android:textSize="14sp"
            android:textColor="#E8D5FF" />
    </LinearLayout>

    <!-- Message content -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:maxWidth="260dp">

        <!-- Typing animation dots (shown when loading) -->
        <LinearLayout
            android:id="@+id/typingDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_assistant_bubble"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <View
                android:id="@+id/dot1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_typing_dot"
                android:layout_marginEnd="4dp" />
            <View
                android:id="@+id/dot2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_typing_dot"
                android:layout_marginEnd="4dp" />
            <View
                android:id="@+id/dot3"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_typing_dot" />
        </LinearLayout>

        <!-- Expandable Thought Section -->
        <LinearLayout
            android:id="@+id/thoughtContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_assistant_bubble"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">
            
            <!-- Toggle Button -->
            <LinearLayout
                android:id="@+id/thoughtToggleBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="💭 View Reasoning"
                    android:textColor="#A094B8"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                    
                <TextView
                    android:id="@+id/thoughtToggleIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▼"
                    android:textColor="#A094B8"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Hidden Thought Text -->
            <TextView
                android:id="@+id/thoughtText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#A094B8"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.3"
                android:visibility="gone" />
        </LinearLayout>

        <!-- AI response text (supports markdown) -->
        <TextView
            android:id="@+id/messageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_assistant_bubble"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:textColor="#EDE8F5"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.4"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
