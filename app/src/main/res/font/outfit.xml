<?xml version="1.0" encoding="utf-8"?>
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <!-- Outfit font - download from Google Fonts and place in res/font/ -->
    <!-- As a fallback, system default sans-serif is used -->
    <font
        android:font="@font/outfit_regular"
        android:fontStyle="normal"
        android:fontWeight="400"
        app:font="@font/outfit_regular"
        app:fontStyle="normal"
        app:fontWeight="400" />
    <font
        android:font="@font/outfit_bold"
        android:fontStyle="normal"
        android:fontWeight="700"
        app:font="@font/outfit_bold"
        app:fontStyle="normal"
        app:fontWeight="700" />
</font-family>
